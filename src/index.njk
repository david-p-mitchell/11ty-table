---
title: Hymns
layout: base.njk
---

<style>
  @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap');

  :root {
    --parchment: #faf7f2;
    --ink: #1c1814;
    --ink-muted: #6b6258;
    --ink-faint: #b8b0a6;
    --rule: #e2d9cf;
    --accent: #8b3a1e;
    --accent-light: #f5ede8;
    --hover-bg: #f5f0ea;
    --card-bg: #ffffff;
  }

  html,body {
    background: var(--parchment);
    color: var(--ink);
    font-family: 'DM Sans', sans-serif;
    width:100%;
    margin: 0;
  }

  .hymns-page {
    margin: 0 auto;
    padding: 2rem 1.25rem 5rem;
  }

  .hymns-header {
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1.25rem;
  }

  .hymns-header-top {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .hymns-header h1 {
    font-family: 'Lora', serif;
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1;
    margin: 0;
  }

  .hymns-header h1 span { font-style: italic; color: var(--accent); }

  .toolbar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .search-wrap {
    position: relative;
    flex: 1;
    min-width: 180px;
  }

  .search-wrap svg {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--ink-faint);
    pointer-events: none;
  }

  #search {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: 6px;
    padding: 0.5rem 1rem 0.5rem 2.1rem;
    width: 100%;
    color: var(--ink);
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  #search::placeholder { color: var(--ink-faint); }
  #search:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(139,58,30,0.08); }

  /* View toggle */
  .view-toggle {
    display: flex;
    border: 1px solid var(--rule);
    border-radius: 6px;
    overflow: hidden;
    flex-shrink: 0;
    background: #fff;
  }

  .view-toggle button {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 0.45rem 0.75rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--ink-muted);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }

  .view-toggle button + button { border-left: 1px solid var(--rule); }
  .view-toggle button.active { background: var(--accent-light); color: var(--accent); font-weight: 500; }

  .row-count {
    font-size: 0.78rem;
    color: var(--ink-faint);
    margin-top: 0.75rem;
  }

  /* TABLE */
  .table-wrap {
    overflow-x: auto;
    border-radius: 8px;
    border: 1px solid var(--rule);
    background: #fff;
  }

  table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  thead tr { border-bottom: 2px solid var(--rule); }

  th {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
    padding: 0.75rem 1rem;
    text-align: left;
    white-space: nowrap;
    cursor: pointer;
    user-select: none;
    transition: color 0.15s;
  }

  th:hover { color: var(--accent); }
  th.sorted { color: var(--accent); }
  th .sort-arrow { display: inline-block; margin-left: 3px; opacity: 0.3; font-size: 0.65rem; }
  th.sorted .sort-arrow { opacity: 1; }

  td {
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--rule);
    color: var(--ink);
    vertical-align: middle;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  tr:last-child td { border-bottom: none; }
  tbody tr { transition: background 0.1s; }
  tbody tr:hover td { background: var(--hover-bg); }
  td:nth-child(1) { font-family: 'Lora', serif; font-size: 0.9rem; max-width: 240px; }
  td:nth-child(2), td:nth-child(3) { font-variant-numeric: tabular-nums; color: var(--ink-muted); font-size: 0.8rem; width: 60px; }

  td a, .card a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s, color 0.15s;
  }

  td a:hover, .card a:hover { color: var(--accent); border-bottom-color: var(--accent); }

  /* CARDS */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .card {
    background: var(--card-bg);
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: 1.1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: box-shadow 0.15s, border-color 0.15s;
  }

  .card:hover { border-color: var(--accent); box-shadow: 0 2px 12px rgba(139,58,30,0.08); }

  .card-title {
    font-family: 'Lora', serif;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
  }

  .card-meta {
    display: flex;
    gap: 0.75rem;
    font-size: 0.75rem;
    color: var(--ink-muted);
    font-variant-numeric: tabular-nums;
  }

  .card-divider { border: none; border-top: 1px solid var(--rule); margin: 0; }

  .card-row {
    display: flex;
    gap: 0.5rem;
    font-size: 0.78rem;
    align-items: baseline;
    flex-wrap: wrap;
  }

  .card-label {
    color: var(--ink-faint);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    min-width: 64px;
    flex-shrink: 0;
    padding-top: 1px;
  }

  .card-value { color: var(--ink); line-height: 1.5; }
  .tags { display: flex; flex-wrap: wrap; gap: 4px; }

  .tag {
    display: inline-block;
    font-size: 0.68rem;
    padding: 2px 7px;
    border-radius: 99px;
    background: var(--accent-light);
    color: var(--accent);
    white-space: nowrap;
  }

  [data-hidden="true"] { display: none !important; }

  /* ERA FILTER */
  .era-filter {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding: 0.75rem 0 0;
  }

  .era-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
    margin-right: 0.25rem;
    flex-shrink: 0;
  }

  .era-btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    padding: 0.3rem 0.75rem;
    border-radius: 99px;
    border: 1px solid var(--rule);
    background: #fff;
    color: var(--ink-muted);
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }

  .era-btn:hover { border-color: var(--accent); color: var(--accent); }
  .era-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; font-weight: 500; }
  .era-btn.all-btn { letter-spacing: 0.02em; }
</style>
{% include "components/disclaimer.njk" %}
<div class="hymns-page">
  <div class="hymns-header">
    <div class="hymns-header-top">
      <h1>The <span>Sing Hymnal</span></h1>
      <div class="view-toggle" role="group" aria-label="View mode">
        <button data-view="table" class="active" onclick="setView('table')" aria-pressed="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18"/></svg>
          Table
        </button>
        <button data-view="card" onclick="setView('card')" aria-pressed="false">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="3" width="9" height="9" rx="1"/><rect x="13" y="3" width="9" height="9" rx="1"/><rect x="2" y="13" width="9" height="9" rx="1"/><rect x="13" y="13" width="9" height="9" rx="1"/></svg>
          Cards
        </button>
      </div>
    </div>
    <div class="toolbar">
      <div class="search-wrap">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="text" id="search" placeholder="Search hymns…" oninput="filterAll()" style="max-width:80%; min-width:50$;" />
      </div>
    </div>
    <div class="era-filter" id="eraFilter">
      <span class="era-label">Era</span>
      <button class="era-btn all-btn active" data-min="0" data-max="9999" onclick="setEra(this)">All</button>
      <button class="era-btn" data-min="0" data-max="999" onclick="setEra(this)">Pre-1000</button>
      <button class="era-btn" data-min="1000" data-max="1499" onclick="setEra(this)">1000–1499</button>
      <button class="era-btn" data-min="1500" data-max="1699" onclick="setEra(this)">1500–1699</button>
      <button class="era-btn" data-min="1700" data-max="1799" onclick="setEra(this)">1700s</button>
      <button class="era-btn" data-min="1800" data-max="1899" onclick="setEra(this)">1800s</button>
      <button class="era-btn" data-min="1900" data-max="1999" onclick="setEra(this)">1900s</button>
      <button class="era-btn" data-min="1950" data-max="1960" onclick="setEra(this)">1950s</button>
        <button class="era-btn" data-min="1960" data-max="1970" onclick="setEra(this)">1960s</button>
        <button class="era-btn" data-min="1970" data-max="1980" onclick="setEra(this)">1970s</button>
        <button class="era-btn" data-min="1980" data-max="1990" onclick="setEra(this)">1980s</button>
        <button class="era-btn" data-min="1990" data-max="2000" onclick="setEra(this)">1990s</button>

        <button class="era-btn" data-min="2000" data-max="2010" onclick="setEra(this)">2000s</button>
        <button class="era-btn" data-min="2010" data-max="2020" onclick="setEra(this)">2010s</button>
        <button class="era-btn" data-min="2020" data-max="2024" onclick="setEra(this)">2020-4</button>
        <button class="era-btn" data-min="2024" data-max="9999" onclick="setEra(this)">2024-6</button>
    </div>
    <p class="row-count" id="rowCount"></p>
  </div>

  <!-- TABLE VIEW -->
  <div class="table-wrap" id="table-view">
    <table id="hymnsTable">
      <thead>
        <tr>
          <th onclick="sortTable(0)">Title <span class="sort-arrow">↕</span></th>
          <th onclick="sortTable(1)"># <span class="sort-arrow">↕</span></th>
          <th onclick="sortTable(2)">Year <span class="sort-arrow">↕</span></th>
          <th onclick="sortTable(3)">Lyricists <span class="sort-arrow">↕</span></th>
          <th onclick="sortTable(4)">Musicians <span class="sort-arrow">↕</span></th>
          <th onclick="sortTable(5)">Keys <span class="sort-arrow">↕</span></th>
          <th onclick="sortTable(6)">Topics <span class="sort-arrow">↕</span></th>
          <th onclick="sortTable(7)">Scriptures <span class="sort-arrow">↕</span></th>
        </tr>
      </thead>
      <tbody>
        {% for h in hymns %}
          <tr data-year="{{ h.year }}" data-search="{{ [h.title, h.hymn_number, h.year, h.lyricists, h.musicians, h.keys, h.topic_tags, h.scripture_tags] | join(' ') | lower }}">
            <td><a href="{{ "https://singhymnal.com" + h.url }}">{{ h.title }}</a></td>
            <td>{{ h.hymn_number }}</td>
            <td>{{ h.year }}</td>
            <td>{{ h.lyricists }}</td>
            <td>{{ h.musicians }}</td>
            <td>{{ h.keys }}</td>
            <td>{{ h.topic_tags }}</td>
            <td>{{ h.scripture_tags }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <!-- CARD VIEW -->
  <div class="cards-grid" id="cards-view" style="display:none;">
    {% for h in hymns %}
      <div class="card" data-year="{{ h.year }}" data-search="{{ [h.title, h.hymn_number, h.year, h.lyricists, h.musicians, h.keys, h.topic_tags, h.scripture_tags] | join(' ') | lower }}">
        <p class="card-title"><a href="{{ "https://singhymnal.com" + h.url }}">{{ h.title }}</a></p>
        <div class="card-meta">
          {% if h.hymn_number %}<span>#{{ h.hymn_number }}</span>{% endif %}
          {% if h.year %}<span>{{ h.year }}</span>{% endif %}
          {% if h.keys %}<span>{{ h.keys | joinList }}</span>{% endif %}
        </div>
        <hr class="card-divider" />
        {% if h.lyricists and h.lyricists.length %}
        <div class="card-row">
            <span class="card-label">Lyricist</span>
            <span class="card-value">{{ h.lyricists | joinList }}</span>
        </div>
        {% endif %}
        {% if h.musicians and h.musicians.length %}
        <div class="card-row">
            <span class="card-label">Musician</span>
            <span class="card-value">{{ h.musicians | joinList }}</span>
        </div>
        {% endif %}
        {% if h.topic_tags %}
        <div class="card-row">
            <span class="card-label">Topics</span>
            <div class="tags">
            {% for tag in h.topic_tags | toTags %}
                <span class="tag">{{ tag }}</span>
            {% endfor %}
            </div>
        </div>
        {% endif %}
        {% if h.scripture_tags %}
          <div class="card-row">
            <span class="card-label">Scripture</span>
            {% for tag in h.scripture_tags  %}
                <span class="card-value">{{ tag }}</span>
            {% endfor %}
          </div>
        {% endif %}
        <audio src="{{h.audio_url}}" controls />
      </div>
    {% endfor %}
  </div>
</div>

<script>
  let sortDir = {};
  let activeEraMin = 0, activeEraMax = 9999;
  const ths = document.querySelectorAll('#hymnsTable thead th');
  const tbody = document.querySelector('#hymnsTable tbody');

  if (window.innerWidth < 640) setView('card');
  updateCount();

  function setView(v) {
    document.getElementById('table-view').style.display = v === 'table' ? '' : 'none';
    document.getElementById('cards-view').style.display = v === 'card' ? 'grid' : 'none';
    document.querySelectorAll('.view-toggle button').forEach(btn => {
      const active = btn.dataset.view === v;
      btn.classList.toggle('active', active);
      btn.setAttribute('aria-pressed', String(active));
    });
  }

  function setEra(btn) {
    activeEraMin = parseInt(btn.dataset.min);
    activeEraMax = parseInt(btn.dataset.max);
    document.querySelectorAll('.era-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    applyFilters();
  }

  function filterAll() { applyFilters(); }

  function applyFilters() {
    const q = document.getElementById('search').value.toLowerCase().trim();
    tbody.querySelectorAll('tr').forEach(row => {
      const year = parseInt(row.dataset.year) || 0;
      const inEra = year >= activeEraMin && year <= activeEraMax;
      const inSearch = !q || row.dataset.search.includes(q);
      row.dataset.hidden = (!inEra || !inSearch) ? 'true' : 'false';
    });
    document.querySelectorAll('#cards-view .card').forEach(card => {
      const year = parseInt(card.dataset.year) || 0;
      const inEra = year >= activeEraMin && year <= activeEraMax;
      const inSearch = !q || card.dataset.search.includes(q);
      card.dataset.hidden = (!inEra || !inSearch) ? 'true' : 'false';
    });
    updateCount();
  }

  function sortTable(col) {
    sortDir[col] = !sortDir[col];
    ths.forEach((th, i) => {
      th.classList.toggle('sorted', i === col);
      th.querySelector('.sort-arrow').textContent = i === col ? (sortDir[col] ? '↑' : '↓') : '↕';
    });
    const rows = [...tbody.querySelectorAll('tr')];
    rows.sort((a, b) => {
      const av = a.cells[col].textContent.trim();
      const bv = b.cells[col].textContent.trim();
      const an = parseFloat(av), bn = parseFloat(bv);
      const numeric = !isNaN(an) && !isNaN(bn);
      return sortDir[col]
        ? (numeric ? an - bn : av.localeCompare(bv))
        : (numeric ? bn - an : bv.localeCompare(av));
    });
    rows.forEach(r => tbody.appendChild(r));
  }

  function updateCount() {
    const all = [...tbody.querySelectorAll('tr')];
    const visible = all.filter(r => r.dataset.hidden !== 'true').length;
    document.getElementById('rowCount').textContent =
      visible === all.length ? `${all.length} hymns` : `${visible} of ${all.length} hymns`;
  }
</script>
